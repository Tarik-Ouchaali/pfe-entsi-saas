# ============================================================
#  ENTSI — SaaS Conformité AO — .env.example
#  Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ------------------------------------------------------------
# APP (Laravel)
# ------------------------------------------------------------
APP_NAME="ENTSI Conformité AO"
APP_ENV=local
APP_KEY=                         # php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8080

# ------------------------------------------------------------
# DATABASE (PostgreSQL)
# ------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=entsi_postgres
DB_PORT=5432
DB_DATABASE=entsi_saas
DB_USERNAME=entsi_user
DB_PASSWORD=entsi_secret

# ------------------------------------------------------------
# REDIS (Queues + Cache)
# ------------------------------------------------------------
REDIS_HOST=entsi_redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ------------------------------------------------------------
# SANCTUM (Auth SPA)
# ------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost

# ------------------------------------------------------------
# MAIL (SMTP)
# ------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@entsi.ma"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------
# SHARED STORAGE (Laravel ↔ FastAPI)
# ------------------------------------------------------------
SHARED_STORAGE_PATH=/var/www/shared-storage
UPLOADS_PATH=/var/www/shared-storage/uploads
OUTPUTS_PATH=/var/www/shared-storage/outputs

# ------------------------------------------------------------
# AI SERVICE (FastAPI)
# ------------------------------------------------------------
AI_SERVICE_URL=http://entsi_ai_service:8000
WEBHOOK_SECRET=ENTSI_SAAS_PRODUCT  # HMAC secret partagé

# ------------------------------------------------------------
# MULTI-TENANCY
# ------------------------------------------------------------
# company_id injecté automatiquement via Global Scope Laravel
# Pas de config spéciale ici — géré dans le code

# ============================================================
# FASTAPI — ai-service/.env (fichier séparé)
# ============================================================
# WEBHOOK_SECRET=change_me_strong_secret_key   # même valeur que dessus
# SHARED_STORAGE_PATH=/app/shared-storage
# LARAVEL_WEBHOOK_URL=http://entsi_laravel:8080/api/webhooks/ai
# LLM_API_KEY=                                 # clé OpenAI / Mistral etc.
# LLM_MODEL=gpt-4o
